---
import Layout from "../layouts/Layout.astro";

const sections = [
  { id: "actions", label: "Actions" },
  { id: "data-display", label: "Data Display" },
  { id: "navigation", label: "Navigation" },
  { id: "feedback", label: "Feedback" },
  { id: "data-input", label: "Data Input" },
  { id: "layout", label: "Layout" },
];
---

<Layout>
  <div class="drawer lg:drawer-open">
    <input id="drawer-toggle" type="checkbox" class="drawer-toggle" />

    <!-- メインコンテンツ -->
    <div class="drawer-content flex flex-col">
      <!-- モバイル用ナビゲーションバー -->
      <div class="navbar bg-base-100 shadow-sm lg:hidden sticky top-0 z-10">
        <label for="drawer-toggle" class="btn btn-ghost drawer-button">
          <svg
            xmlns="http://www.w3.org/2000/svg"
            class="h-5 w-5"
            fill="none"
            viewBox="0 0 24 24"
            stroke="currentColor"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              stroke-width="2"
              d="M4 6h16M4 12h16M4 18h16"></path>
          </svg>
        </label>
        <span class="text-xl font-bold">Component Gallery</span>
      </div>

      <div class="p-8 max-w-4xl space-y-20">
        <div>
          <h1 class="text-3xl font-bold mb-2">DaisyUI Component Gallery</h1>
          <p class="text-base-content/60">
            Tailwind CSS v4 + DaisyUI v5 のコンポーネント一覧
          </p>
        </div>

        <!-- ========== Actions ========== -->
        <section id="actions">
          <h2 class="text-2xl font-bold mb-8 border-b pb-3">Actions</h2>

          <!-- Button -->
          <div class="mb-10">
            <h3 class="text-lg font-semibold mb-4">Button</h3>
            <div class="flex flex-wrap gap-3">
              <button class="btn">Default</button>
              <button class="btn btn-primary">Primary</button>
              <button class="btn btn-secondary">Secondary</button>
              <button class="btn btn-accent">Accent</button>
              <button class="btn btn-ghost">Ghost</button>
              <button class="btn btn-link">Link</button>
              <button class="btn btn-outline btn-primary">Outline</button>
              <button class="btn btn-soft btn-primary">Soft</button>
              <button class="btn btn-dash btn-primary">Dash</button>
              <button class="btn btn-error">Error</button>
              <button class="btn btn-warning">Warning</button>
              <button class="btn btn-success">Success</button>
              <button class="btn btn-info">Info</button>
              <button class="btn" disabled>Disabled</button>
            </div>
            <div class="flex flex-wrap gap-3 mt-3">
              <button class="btn btn-xs">XSmall</button>
              <button class="btn btn-sm">Small</button>
              <button class="btn btn-md">Medium</button>
              <button class="btn btn-lg">Large</button>
              <button class="btn btn-xl">XLarge</button>
              <button class="btn btn-primary btn-wide">Wide</button>
              <button class="btn btn-primary btn-circle">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-5 w-5"
                  viewBox="0 0 20 20"
                  fill="currentColor"
                >
                  <path
                    fill-rule="evenodd"
                    d="M10 3a1 1 0 011 1v5h5a1 1 0 110 2h-5v5a1 1 0 11-2 0v-5H4a1 1 0 110-2h5V4a1 1 0 011-1z"
                    clip-rule="evenodd"></path>
                </svg>
              </button>
              <button class="btn btn-primary loading">Loading</button>
            </div>
          </div>

          <!-- Dropdown -->
          <div class="mb-10">
            <h3 class="text-lg font-semibold mb-4">Dropdown</h3>
            <div class="flex flex-wrap gap-4">
              <div class="dropdown">
                <div tabindex="0" role="button" class="btn m-1">Click</div>
                <ul
                  tabindex="0"
                  class="dropdown-content menu bg-base-100 rounded-box z-10 w-52 p-2 shadow-sm"
                >
                  <li><a>Item 1</a></li>
                  <li><a>Item 2</a></li>
                  <li><a>Item 3</a></li>
                </ul>
              </div>
              <div class="dropdown dropdown-hover">
                <div tabindex="0" role="button" class="btn m-1">Hover</div>
                <ul
                  tabindex="0"
                  class="dropdown-content menu bg-base-100 rounded-box z-10 w-52 p-2 shadow-sm"
                >
                  <li><a>Item 1</a></li>
                  <li><a>Item 2</a></li>
                </ul>
              </div>
              <div class="dropdown dropdown-end">
                <div tabindex="0" role="button" class="btn btn-primary m-1">
                  Align End
                </div>
                <ul
                  tabindex="0"
                  class="dropdown-content menu bg-base-100 rounded-box z-10 w-52 p-2 shadow-sm"
                >
                  <li><a>Item 1</a></li>
                  <li><a>Item 2</a></li>
                </ul>
              </div>
            </div>
          </div>

          <!-- Modal -->
          <div class="mb-10">
            <h3 class="text-lg font-semibold mb-4">Modal</h3>
            <div class="flex gap-3">
              <button class="btn btn-primary" id="open-modal-basic"
                >Open Modal</button
              >
              <button class="btn btn-secondary" id="open-modal-form"
                >Form Modal</button
              >
            </div>

            <dialog id="modal-basic" class="modal">
              <div class="modal-box">
                <h3 class="text-lg font-bold">Hello!</h3>
                <p class="py-4">
                  Press ESC key or click the button below to close
                </p>
                <div class="modal-action">
                  <form method="dialog">
                    <button class="btn">Close</button>
                  </form>
                </div>
              </div>
              <form method="dialog" class="modal-backdrop">
                <button>close</button>
              </form>
            </dialog>

            <dialog id="modal-form" class="modal">
              <div class="modal-box">
                <h3 class="text-lg font-bold mb-4">Form Modal</h3>
                <fieldset class="fieldset">
                  <legend class="fieldset-legend">Name</legend>
                  <input
                    type="text"
                    class="input input-bordered w-full"
                    placeholder="Enter your name"
                  />
                </fieldset>
                <fieldset class="fieldset mt-3">
                  <legend class="fieldset-legend">Email</legend>
                  <input
                    type="email"
                    class="input input-bordered w-full"
                    placeholder="Enter your email"
                  />
                </fieldset>
                <div class="modal-action">
                  <form method="dialog">
                    <button class="btn btn-ghost mr-2">Cancel</button>
                    <button class="btn btn-primary">Submit</button>
                  </form>
                </div>
              </div>
              <form method="dialog" class="modal-backdrop">
                <button>close</button>
              </form>
            </dialog>
          </div>

          <!-- Swap -->
          <div class="mb-10">
            <h3 class="text-lg font-semibold mb-4">Swap</h3>
            <div class="flex gap-4">
              <label class="swap swap-rotate btn btn-ghost btn-circle">
                <input type="checkbox" />
                <svg
                  class="swap-on h-6 w-6 fill-current"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                >
                  <path
                    d="M5.64,17l-.71.71a1,1,0,0,0,0,1.41,1,1,0,0,0,1.41,0l.71-.71A1,1,0,0,0,5.64,17ZM5,12a1,1,0,0,0-1-1H3a1,1,0,0,0,0,2H4A1,1,0,0,0,5,12Zm7-7a1,1,0,0,0,1-1V3a1,1,0,0,0-2,0V4A1,1,0,0,0,12,5ZM5.64,7.05a1,1,0,0,0,.7.29,1,1,0,0,0,.71-.29,1,1,0,0,0,0-1.41l-.71-.71A1,1,0,0,0,4.93,6.34Zm12,.29a1,1,0,0,0,.7-.29l.71-.71a1,1,0,1,0-1.41-1.41L17,5.64a1,1,0,0,0,0,1.41A1,1,0,0,0,17.66,7.34ZM21,11H20a1,1,0,0,0,0,2h1a1,1,0,0,0,0-2Zm-9,8a1,1,0,0,0-1,1v1a1,1,0,0,0,2,0V20A1,1,0,0,0,12,19ZM18.36,17A1,1,0,0,0,17,18.36l.71.71a1,1,0,0,0,1.41,0,1,1,0,0,0,0-1.41ZM12,6.5A5.5,5.5,0,1,0,17.5,12,5.51,5.51,0,0,0,12,6.5Zm0,9A3.5,3.5,0,1,1,15.5,12,3.5,3.5,0,0,1,12,15.5Z"
                  ></path>
                </svg>
                <svg
                  class="swap-off h-6 w-6 fill-current"
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                >
                  <path
                    d="M21.64,13a1,1,0,0,0-1.05-.14,8.05,8.05,0,0,1-3.37.73A8.15,8.15,0,0,1,9.08,5.49a8.59,8.59,0,0,1,.25-2A1,1,0,0,0,8,2.36,10.14,10.14,0,1,0,22,14.05,1,1,0,0,0,21.64,13Zm-9.5,6.69A8.14,8.14,0,0,1,7.08,5.22v.27A10.15,10.15,0,0,0,17.22,15.63a9.79,9.79,0,0,0,2.1-.22A8.11,8.11,0,0,1,12.14,19.73Z"
                  ></path>
                </svg>
              </label>
              <label class="swap btn btn-ghost gap-2">
                <input type="checkbox" />
                <span class="swap-off">OFF</span>
                <span class="swap-on text-success font-bold">ON</span>
              </label>
            </div>
          </div>
        </section>

        <!-- ========== Data Display ========== -->
        <section id="data-display">
          <h2 class="text-2xl font-bold mb-8 border-b pb-3">Data Display</h2>

          <!-- Alert -->
          <div class="mb-10">
            <h3 class="text-lg font-semibold mb-4">Alert</h3>
            <div class="flex flex-col gap-3">
              <div role="alert" class="alert alert-info">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-6 w-6 shrink-0 stroke-current"
                  fill="none"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"
                  ></path>
                </svg>
                <span>Info: New software update available.</span>
              </div>
              <div role="alert" class="alert alert-success">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-6 w-6 shrink-0 stroke-current"
                  fill="none"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                </svg>
                <span>Success: Your purchase has been confirmed!</span>
              </div>
              <div role="alert" class="alert alert-warning">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-6 w-6 shrink-0 stroke-current"
                  fill="none"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"
                  ></path>
                </svg>
                <span>Warning: Invalid email address!</span>
              </div>
              <div role="alert" class="alert alert-error">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  class="h-6 w-6 shrink-0 stroke-current"
                  fill="none"
                  viewBox="0 0 24 24"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    stroke-width="2"
                    d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"
                  ></path>
                </svg>
                <span>Error: File upload failed. Try again.</span>
              </div>
            </div>
          </div>

          <!-- Badge -->
          <div class="mb-10">
            <h3 class="text-lg font-semibold mb-4">Badge</h3>
            <div class="flex flex-wrap gap-3">
              <span class="badge">Default</span>
              <span class="badge badge-primary">Primary</span>
              <span class="badge badge-secondary">Secondary</span>
              <span class="badge badge-accent">Accent</span>
              <span class="badge badge-ghost">Ghost</span>
              <span class="badge badge-info">Info</span>
              <span class="badge badge-success">Success</span>
              <span class="badge badge-warning">Warning</span>
              <span class="badge badge-error">Error</span>
              <span class="badge badge-outline badge-primary">Outline</span>
              <span class="badge badge-soft badge-primary">Soft</span>
              <span class="badge badge-xs">XSmall</span>
              <span class="badge badge-sm badge-primary">Small</span>
              <span class="badge badge-md badge-secondary">Medium</span>
              <span class="badge badge-lg badge-accent">Large</span>
            </div>
          </div>

          <!-- Card -->
          <div class="mb-10">
            <h3 class="text-lg font-semibold mb-4">Card</h3>
            <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
              <div class="card bg-base-100 shadow-md">
                <div class="card-body">
                  <h2 class="card-title">Card Title</h2>
                  <p>カードの説明文がここに入ります。</p>
                  <div class="card-actions justify-end">
                    <button class="btn btn-primary btn-sm">Action</button>
                  </div>
                </div>
              </div>
              <div class="card card-border bg-base-100">
                <div class="card-body">
                  <h2 class="card-title">
                    Border Card
                    <span class="badge badge-secondary badge-sm">New</span>
                  </h2>
                  <p>ボーダースタイルのカード。</p>
                  <div class="card-actions">
                    <button class="btn btn-ghost btn-sm">Cancel</button>
                    <button class="btn btn-primary btn-sm">Confirm</button>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- Accordion -->
          <div class="mb-10">
            <h3 class="text-lg font-semibold mb-4">Accordion</h3>
            <div class="join join-vertical w-full">
              <div
                class="collapse collapse-arrow join-item border border-base-300"
              >
                <input type="radio" name="accordion" checked />
                <div class="collapse-title text-md font-medium">
                  What is DaisyUI?
                </div>
                <div class="collapse-content">
                  <p>
                    DaisyUI は Tailwind CSS
                    をベースにしたコンポーネントライブラリです。
                  </p>
                </div>
              </div>
              <div
                class="collapse collapse-arrow join-item border border-base-300"
              >
                <input type="radio" name="accordion" />
                <div class="collapse-title text-md font-medium">
                  How to install?
                </div>
                <div class="collapse-content">
                  <p>
                    <code class="kbd kbd-sm">pnpm add tailwindcss daisyui</code> を実行してください。
                  </p>
                </div>
              </div>
              <div
                class="collapse collapse-arrow join-item border border-base-300"
              >
                <input type="radio" name="accordion" />
                <div class="collapse-title text-md font-medium">
                  Is it free?
                </div>
                <div class="collapse-content">
                  <p>はい、MIT ライセンスで無料で利用できます。</p>
                </div>
              </div>
            </div>
          </div>

          <!-- Stats -->
          <div class="mb-10">
            <h3 class="text-lg font-semibold mb-4">Stats</h3>
            <div class="stats stats-vertical sm:stats-horizontal shadow w-full">
              <div class="stat">
                <div class="stat-figure text-primary">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    class="inline-block h-8 w-8 stroke-current"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"
                    ></path>
                  </svg>
                </div>
                <div class="stat-title">Total Likes</div>
                <div class="stat-value text-primary">25.6K</div>
                <div class="stat-desc">21% more than last month</div>
              </div>
              <div class="stat">
                <div class="stat-figure text-secondary">
                  <svg
                    xmlns="http://www.w3.org/2000/svg"
                    fill="none"
                    viewBox="0 0 24 24"
                    class="inline-block h-8 w-8 stroke-current"
                  >
                    <path
                      stroke-linecap="round"
                      stroke-linejoin="round"
                      stroke-width="2"
                      d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                  </svg>
                </div>
                <div class="stat-title">Page Views</div>
                <div class="stat-value text-secondary">2.6M</div>
                <div class="stat-desc">↗︎ 400 (22%)</div>
              </div>
              <div class="stat">
                <div class="stat-title">New Users</div>
                <div class="stat-value">1,200</div>
                <div class="stat-desc">↘︎ 90 (14%)</div>
              </div>
            </div>
          </div>

          <!-- Table -->
          <div class="mb-10">
            <h3 class="text-lg font-semibold mb-4">Table</h3>
            <div class="overflow-x-auto">
              <table class="table table-zebra">
                <thead>
                  <tr>
                    <th>#</th>
                    <th>Name</th>
                    <th>Role</th>
                    <th>Status</th>
                  </tr>
                </thead>
                <tbody>
                  <tr>
                    <th>1</th>
                    <td>Cy Ganderton</td>
                    <td>Engineer</td>
                    <td
                      ><span class="badge badge-success badge-sm">Active</span
                      ></td
                    >
                  </tr>
                  <tr>
                    <th>2</th>
                    <td>Hart Hagerty</td>
                    <td>Designer</td>
                    <td
                      ><span class="badge badge-warning badge-sm">Pending</span
                      ></td
                    >
                  </tr>
                  <tr>
                    <th>3</th>
                    <td>Brice Swyre</td>
                    <td>Manager</td>
                    <td
                      ><span class="badge badge-error badge-sm">Inactive</span
                      ></td
                    >
                  </tr>
                </tbody>
              </table>
            </div>
          </div>

          <!-- Tooltip -->
          <div class="mb-10">
            <h3 class="text-lg font-semibold mb-4">Tooltip</h3>
            <div class="flex flex-wrap gap-4">
              <div class="tooltip" data-tip="Default tooltip">
                <button class="btn">Hover me</button>
              </div>
              <div
                class="tooltip tooltip-top tooltip-primary"
                data-tip="Primary"
              >
                <button class="btn btn-primary">Top</button>
              </div>
              <div
                class="tooltip tooltip-bottom tooltip-secondary"
                data-tip="Secondary"
              >
                <button class="btn btn-secondary">Bottom</button>
              </div>
              <div
                class="tooltip tooltip-left tooltip-accent"
                data-tip="Accent"
              >
                <button class="btn btn-accent">Left</button>
              </div>
              <div
                class="tooltip tooltip-right tooltip-success"
                data-tip="Success"
              >
                <button class="btn btn-success">Right</button>
              </div>
            </div>
          </div>

          <!-- Avatar -->
          <div class="mb-10">
            <h3 class="text-lg font-semibold mb-4">Avatar</h3>
            <div class="flex flex-wrap gap-4 items-end">
              <div class="avatar">
                <div
                  class="w-16 rounded-full ring ring-primary ring-offset-base-100 ring-offset-2"
                >
                  <img
                    src="https://img.daisyui.com/images/stock/photo-1534528741775-53994a69daeb.webp"
                    alt="avatar"
                  />
                </div>
              </div>
              <div class="avatar">
                <div class="w-12 rounded-full">
                  <img
                    src="https://img.daisyui.com/images/stock/photo-1534528741775-53994a69daeb.webp"
                    alt="avatar"
                  />
                </div>
              </div>
              <div class="avatar avatar-online">
                <div class="w-12 rounded-full">
                  <img
                    src="https://img.daisyui.com/images/stock/photo-1534528741775-53994a69daeb.webp"
                    alt="avatar"
                  />
                </div>
              </div>
              <div class="avatar avatar-offline">
                <div class="w-12 rounded-full">
                  <img
                    src="https://img.daisyui.com/images/stock/photo-1534528741775-53994a69daeb.webp"
                    alt="avatar"
                  />
                </div>
              </div>
              <div class="avatar placeholder">
                <div class="bg-neutral text-neutral-content w-12 rounded-full">
                  <span class="text-xl">A</span>
                </div>
              </div>
              <div class="avatar-group -space-x-4">
                <div class="avatar">
                  <div class="w-10">
                    <img
                      src="https://img.daisyui.com/images/stock/photo-1534528741775-53994a69daeb.webp"
                      alt="avatar"
                    />
                  </div>
                </div>
                <div class="avatar">
                  <div class="w-10">
                    <img
                      src="https://img.daisyui.com/images/stock/photo-1534528741775-53994a69daeb.webp"
                      alt="avatar"
                    />
                  </div>
                </div>
                <div class="avatar placeholder">
                  <div class="bg-neutral text-neutral-content w-10">
                    <span>+3</span>
                  </div>
                </div>
              </div>
            </div>
          </div>

          <!-- KBD -->
          <div class="mb-10">
            <h3 class="text-lg font-semibold mb-4">KBD</h3>
            <div class="flex flex-wrap gap-2">
              <kbd class="kbd">⌘</kbd>
              <kbd class="kbd">+</kbd>
              <kbd class="kbd">K</kbd>
              <span class="mx-2">or</span>
              <kbd class="kbd kbd-sm">Ctrl</kbd>
              <kbd class="kbd kbd-sm">+</kbd>
              <kbd class="kbd kbd-sm">Shift</kbd>
              <kbd class="kbd kbd-sm">+</kbd>
              <kbd class="kbd kbd-sm">P</kbd>
            </div>
          </div>
        </section>

        <!-- ========== Navigation ========== -->
        <section id="navigation">
          <h2 class="text-2xl font-bold mb-8 border-b pb-3">Navigation</h2>

          <!-- Tabs -->
          <div class="mb-10">
            <h3 class="text-lg font-semibold mb-4">Tabs</h3>
            <div role="tablist" class="tabs tabs-border mb-4">
              <input
                type="radio"
                name="tabs-border"
                role="tab"
                class="tab"
                aria-label="Tab 1"
                checked
              />
              <div
                role="tabpanel"
                class="tab-content p-4 border border-base-300 rounded-b-box"
              >
