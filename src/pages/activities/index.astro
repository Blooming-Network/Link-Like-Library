---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const entries = (await getCollection("activities")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);

const thumbVariants = [
  "article-card-thumb-a",
  "article-card-thumb-b",
  "article-card-thumb-c",
] as const;
---

<Layout
  title="活動記録"
  description="蓮ノ空女学院スクールアイドルクラブの歩みを綴った活動記録に関する記事一覧です。"
>
  <main class="page-shell">
    <header class="page-header">
      <h1 class="page-title">活動記録</h1>
      <p class="page-lead">
        蓮ノ空女学院スクールアイドルクラブの歩みを綴った活動記録に関する記事一覧です。
      </p>
    </header>

    {
      entries.length === 0 ? (
        <div class="empty-state">
          <div class="empty-icon">＊</div>
          <p class="empty-title">まだ活動記録がありません</p>
          <p class="empty-body">
            記事は src/content/activities/ に Markdown で追加できます。
          </p>
        </div>
      ) : (
        <section class="article-grid">
          {entries.map((entry, i) => (
            <a href={`/activities/${entry.id}`} class="article-card">
              <div
                class={`article-card-thumb ${thumbVariants[i % thumbVariants.length]}`}
              />
              <div class="article-card-body">
                <h2 class="article-card-title">{entry.data.title}</h2>
                <p class="article-card-excerpt">{entry.data.description}</p>
                <time
                  class="article-card-date"
                  datetime={entry.data.date.toISOString()}
                >
                  {entry.data.date.toLocaleDateString("ja-JP", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </time>
              </div>
            </a>
          ))}
        </section>
      )
    }
  </main>
</Layout>
