---
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";

const posts = (await getCollection("posts")).sort(
  (a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<Layout>
  <div class="min-h-screen bg-base-100">
    <div class="max-w-3xl mx-auto px-6 py-12">
      <h1 class="text-3xl font-bold mb-8">Posts</h1>

      <div class="flex flex-col gap-4">
        {
          posts.map((post) => (
            <a
              href={`/posts/${post.id}`}
              class="card bg-base-100 shadow-sm border border-base-300 hover:shadow-md transition-shadow"
            >
              <div class="card-body">
                <h2 class="card-title">{post.data.title}</h2>
                <p class="text-base-content/60">{post.data.description}</p>
                <div class="text-sm text-base-content/40">
                  {post.data.date.toLocaleDateString("ja-JP", {
                    year: "numeric",
                    month: "long",
                    day: "numeric",
                  })}
                </div>
              </div>
            </a>
          ))
        }
      </div>
    </div>
  </div>
</Layout>
